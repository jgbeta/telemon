#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="/etc/telemon"
CONFIG_FILE="$CONFIG_DIR/exporter.yml"
PROMETHEUS_IP_FILE="$CONFIG_DIR/prometheus-server-ip"
PROMETHEUS_FIREWALL_FILE="$CONFIG_DIR/prometheus-firewall-rule"
STATE_DIR="/var/lib/telemon/exporter"
PACKAGE_BINARY="/usr/bin/telemon-exporter"
BOOTSTRAP_BINARY="/usr/local/bin/telemon-exporter"
SYSTEMD_OVERRIDE_UNIT="/etc/systemd/system/telemon-exporter.service"

firewall_scrape_port() {
  local port
  port="$(awk '
    /^[^[:space:]][^:]*:/ {
      current = $1
      sub(":", "", current)
    }
    current == "registration" && $1 == "scrape_port:" {
      print $2
    }
  ' "$CONFIG_FILE" 2>/dev/null | tail -n 1)"

  case "$port" in
    ''|*[!0-9]*|0)
      printf '9185\n'
      ;;
    *)
      printf '%s\n' "$port"
      ;;
  esac
}

write_firewall_state() {
  local prometheus_ip="$1"
  local scrape_port="$2"
  local managed="$3"

  install -d -m 0755 "$CONFIG_DIR"
  printf '%s\n' "$prometheus_ip" > "$PROMETHEUS_IP_FILE"
  chmod 0644 "$PROMETHEUS_IP_FILE"
  cat > "$PROMETHEUS_FIREWALL_FILE" <<STATE
backend=ufw
source_ip=$prometheus_ip
port=$scrape_port
managed=$managed
STATE
  chmod 0644 "$PROMETHEUS_FIREWALL_FILE"
}

firewall_value() {
  local key="$1"
  awk -F= -v key="$key" '$1 == key { print substr($0, length(key) + 2) }' "$PROMETHEUS_FIREWALL_FILE" 2>/dev/null | tail -n 1
}

config_value() {
  local section="$1"
  local key="$2"
  awk -v section="$section" -v key="$key" '
    /^[^[:space:]][^:]*:/ {
      current = $1
      sub(":", "", current)
    }
    current == section && $1 == key ":" {
      value = $0
      sub("^[[:space:]]*" key ":[[:space:]]*", "", value)
      gsub(/^"|"$/, "", value)
      print value
    }
  ' "$CONFIG_FILE" 2>/dev/null | tail -n 1
}

host_from_addr() {
  local value="$1"
  value="${value#http://}"
  value="${value#https://}"
  printf '%s\n' "${value%%:*}"
}

recorded_prometheus_ip() {
  if [ -f "$PROMETHEUS_FIREWALL_FILE" ]; then
    firewall_value source_ip
  elif [ -f "$PROMETHEUS_IP_FILE" ]; then
    tr -d '[:space:]' < "$PROMETHEUS_IP_FILE"
  fi
}

resolve_prometheus_ip() {
  local prometheus_ip registry_addr

  if [ -n "${TELEMON_PROMETHEUS_IP:-}" ]; then
    return 0
  fi

  prometheus_ip="$(recorded_prometheus_ip)"
  if [ -n "$prometheus_ip" ]; then
    TELEMON_PROMETHEUS_IP="$prometheus_ip"
    export TELEMON_PROMETHEUS_IP
    return 0
  fi

  registry_addr="$(config_value registration registry_addr)"
  if [ -z "$registry_addr" ]; then
    registry_addr="${TELEMON_REGISTRY_SERVER:-}"
  fi
  if [ -n "$registry_addr" ]; then
    prometheus_ip="$(host_from_addr "$registry_addr")"
    if [ -n "$prometheus_ip" ]; then
      TELEMON_PROMETHEUS_IP="$prometheus_ip"
      export TELEMON_PROMETHEUS_IP
    fi
  fi
}

previous_firewall_rule_was_managed() {
  local prometheus_ip="$1"
  local scrape_port="$2"

  [ -f "$PROMETHEUS_FIREWALL_FILE" ] || return 1
  [ "$(firewall_value source_ip)" = "$prometheus_ip" ] || return 1
  [ "$(firewall_value port)" = "$scrape_port" ] || return 1
  [ "$(firewall_value managed)" = "true" ] || return 1
}

configure_ufw_for_prometheus() {
  local prometheus_ip="${TELEMON_PROMETHEUS_IP:-}"
  local scrape_port output managed
  [ -n "$prometheus_ip" ] || return 0

  scrape_port="$(firewall_scrape_port)"

  if ! command -v ufw >/dev/null 2>&1; then
    echo "UFW not found; allow Prometheus manually: TCP $scrape_port from $prometheus_ip" >&2
    return 0
  fi

  output="$(ufw allow from "$prometheus_ip" to any port "$scrape_port" proto tcp comment 'telemon prometheus scrape' 2>&1)"
  printf '%s\n' "$output"
  managed="true"
  case "$output" in
    *'Skipping adding existing rule'*)
      if previous_firewall_rule_was_managed "$prometheus_ip" "$scrape_port"; then
        managed="true"
      else
        managed="false"
      fi
      ;;
  esac
  write_firewall_state "$prometheus_ip" "$scrape_port" "$managed"

  if ufw status 2>/dev/null | grep -q '^Status: active'; then
    ufw reload
  else
    echo "UFW rule added, but UFW is inactive; not enabling UFW automatically" >&2
  fi
}

timestamp() {
  date +%Y%m%d%H%M%S
}

backup_path() {
  local path="$1"
  printf '%s.telemon-backup-%s\n' "$path" "$(timestamp)"
}

unit_uses_package_binary() {
  local unit_file="$1"
  grep -Eq "^[[:space:]]*ExecStart=.*${PACKAGE_BINARY}([[:space:]]|$)" "$unit_file" 2>/dev/null
}

migrate_stale_systemd_override() {
  local backup

  [ -e "$SYSTEMD_OVERRIDE_UNIT" ] || return 0
  if unit_uses_package_binary "$SYSTEMD_OVERRIDE_UNIT"; then
    return 0
  fi

  backup="$(backup_path "$SYSTEMD_OVERRIDE_UNIT")"
  mv "$SYSTEMD_OVERRIDE_UNIT" "$backup"
  echo "Backed up stale Telemon systemd override to $backup"
}

backup_stale_bootstrap_binary() {
  local backup

  [ -x "$BOOTSTRAP_BINARY" ] || return 0
  [ -x "$PACKAGE_BINARY" ] || return 0
  if cmp -s "$BOOTSTRAP_BINARY" "$PACKAGE_BINARY"; then
    return 0
  fi

  backup="$(backup_path "$BOOTSTRAP_BINARY")"
  mv "$BOOTSTRAP_BINARY" "$backup"
  echo "Backed up stale bootstrap binary to $backup"
}

verify_package_systemd_unit() {
  local fragment exec_start

  command -v systemctl >/dev/null 2>&1 || return 0
  fragment="$(systemctl show -p FragmentPath --value telemon-exporter.service 2>/dev/null || true)"
  exec_start="$(systemctl show -p ExecStart --value telemon-exporter.service 2>/dev/null || true)"

  case "$fragment" in
    /lib/systemd/system/telemon-exporter.service|/usr/lib/systemd/system/telemon-exporter.service)
      ;;
    *)
      echo "warning: telemon-exporter service is not using the package unit: ${fragment:-unknown}" >&2
      ;;
  esac

  case "$exec_start" in
    *"$PACKAGE_BINARY"*)
      ;;
    *)
      echo "warning: telemon-exporter service is not using $PACKAGE_BINARY: ${exec_start:-unknown}" >&2
      ;;
  esac
}

sed_escape() {
  printf '%s' "$1" | sed 's/[\/&|\\]/\\&/g'
}

update_config_value() {
  local section="$1"
  local key="$2"
  local value
  local mode="${4:-string}"
  local temp_file
  value="$(sed_escape "$3")"
  temp_file="$(mktemp)"
  awk -v section="$section" -v key="$key" -v value="$value" -v mode="$mode" '
    /^[^[:space:]][^:]*:/ {
      current = $1
      sub(":", "", current)
    }
    current == section && $1 == key ":" {
      if (mode == "raw") {
        print "  " key ": " value
      } else {
        print "  " key ": \"" value "\""
      }
      next
    }
    { print }
  ' "$CONFIG_FILE" > "$temp_file"
  install -m 0644 "$temp_file" "$CONFIG_FILE"
  rm -f "$temp_file"
}

ensure_config_key() {
  local section="$1"
  local key="$2"
  local line="$3"
  local temp_file

  if awk -v section="$section" -v key="$key" '
    /^[^[:space:]][^:]*:/ {
      current = $1
      sub(":", "", current)
    }
    current == section && $1 == key ":" {
      found = 1
    }
    END {
      exit found ? 0 : 1
    }
  ' "$CONFIG_FILE"; then
    return
  fi

  temp_file="$(mktemp)"
  awk -v section="$section" -v line="$line" '
    /^[^[:space:]][^:]*:/ {
      if (in_section && !inserted) {
        print line
        inserted = 1
      }
      current = $1
      sub(":", "", current)
      in_section = (current == section)
    }
    { print }
    END {
      if (in_section && !inserted) {
        print line
      }
    }
  ' "$CONFIG_FILE" > "$temp_file"
  install -m 0644 "$temp_file" "$CONFIG_FILE"
  rm -f "$temp_file"
}

ensure_registration_config_shape() {
  if ! grep -q '^identity:' "$CONFIG_FILE"; then
    cat >> "$CONFIG_FILE" <<'CONFIG'

identity:
  user_name: ""
  device_name: ""
  machine_uuid: ""
  machine_uuid_file: ""
CONFIG
  fi

  if ! grep -q '^registration:' "$CONFIG_FILE"; then
    cat >> "$CONFIG_FILE" <<'CONFIG'

registration:
  enabled: false
  registry_addr: ""
  enrollment_token: ""
  device_id_file: ""
  heartbeat_interval_seconds: 30
  scrape_port: 9185
  advertised_addr: ""
CONFIG
  fi

  ensure_config_key "identity" "machine_uuid" '  machine_uuid: ""'
  ensure_config_key "identity" "machine_uuid_file" '  machine_uuid_file: ""'
  ensure_config_key "registration" "advertised_addr" '  advertised_addr: ""'
}

configure_registration_config() {
  local registry_server="${TELEMON_REGISTRY_SERVER:-}"
  local enrollment_token="${TELEMON_ENROLLMENT_TOKEN:-}"
  local user_name="${TELEMON_USER_NAME:-}"
  local device_name="${TELEMON_DEVICE_NAME:-${HOSTNAME:-}}"
  local advertised_addr="${TELEMON_ADVERTISED_ADDR:-}"
  local machine_uuid="${TELEMON_MACHINE_UUID:-}"

  if [ -z "$registry_server" ]; then
    return
  fi

  if [ -z "$enrollment_token" ] || [ -z "$user_name" ]; then
    echo "registration not configured; TELEMON_REGISTRY_SERVER requires TELEMON_ENROLLMENT_TOKEN and TELEMON_USER_NAME" >&2
    return
  fi

  update_config_value "identity" "user_name" "$user_name"
  update_config_value "identity" "device_name" "$device_name"
  if [ -n "$machine_uuid" ]; then
    update_config_value "identity" "machine_uuid" "$machine_uuid"
  fi
  update_config_value "registration" "enabled" "true" "raw"
  update_config_value "registration" "registry_addr" "$registry_server"
  update_config_value "registration" "enrollment_token" "$enrollment_token"
  update_config_value "registration" "device_id_file" "$STATE_DIR/device-id"
  if [ -n "$advertised_addr" ]; then
    update_config_value "registration" "advertised_addr" "$advertised_addr"
  fi

  if [ -z "${TELEMON_PROMETHEUS_IP:-}" ]; then
    TELEMON_PROMETHEUS_IP="${registry_server%%:*}"
    export TELEMON_PROMETHEUS_IP
  fi
}

registration_is_enabled() {
  awk '
    /^[^[:space:]][^:]*:/ {
      current = $1
      sub(":", "", current)
    }
    current == "registration" && $1 == "enabled:" && $2 == "true" {
      found = 1
    }
    END {
      exit found ? 0 : 1
    }
  ' "$CONFIG_FILE" 2>/dev/null
}

if ! getent group telemon >/dev/null 2>&1; then
  groupadd --system telemon
fi

if ! id -u telemon >/dev/null 2>&1; then
  useradd --system --no-create-home --shell /usr/sbin/nologin --gid telemon telemon
fi

install -d -m 0755 "$CONFIG_DIR"
install -d -m 0750 -o telemon -g telemon "$STATE_DIR"
ensure_registration_config_shape
configure_registration_config
resolve_prometheus_ip
if [ -z "${TELEMON_REGISTRY_SERVER:-}" ] && ! registration_is_enabled; then
  cat >&2 <<'MESSAGE'
telemon-exporter installed without registry enrollment.
Run this command to configure enrollment interactively:

  sudo telemon-exporter-setup
MESSAGE
fi
configure_ufw_for_prometheus

if command -v systemctl >/dev/null 2>&1; then
  migrate_stale_systemd_override
  backup_stale_bootstrap_binary
  systemctl daemon-reload || true
  systemctl enable telemon-exporter.service || true
  systemctl restart telemon-exporter.service || true
  verify_package_systemd_unit
fi

exit 0
